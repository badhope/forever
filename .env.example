# Forever · 永生 - 环境变量配置

# === LLM 配置（任选一个） ===
# 通用配置
# FOREVER_LLM_PROVIDER=aliyun_bailian
# FOREVER_LLM_API_KEY=your-api-key
# FOREVER_LLM_MODEL=qwen-max

# 阿里百炼
# DASHSCOPE_API_KEY=your-api-key

# DeepSeek
# DEEPSEEK_API_KEY=your-api-key

# 智谱AI
# ZHIPU_API_KEY=your-api-key

# 月之暗面
# MOONSHOT_API_KEY=your-api-key

# 硅基流动
# SILICONFLOW_API_KEY=your-api-key

# OpenAI
# OPENAI_API_KEY=your-api-key

# Anthropic Claude
# ANTHROPIC_API_KEY=your-api-key

# Ollama（本地，无需API Key）
# FOREVER_LLM_PROVIDER=ollama

# === 记忆系统 ===
# FOREVER_DATA_DIR=/tmp/forever

# === TTS ===
# FOREVER_TTS_ENABLED=false

# === Avatar ===
# FOREVER_SADTALKER_PATH=/path/to/SadTalker

# === 日志 ===
# FOREVER_LOG_LEVEL=INFO

# === 伦理 ===
# FOREVER_MAX_DAILY_CONVERSATIONS=50
# FOREVER_MAX_CONSECUTIVE_DAYS=14
