
# Forever AI Environment Configuration
# Development Environment - Default Values

# Node Environment
NODE_ENV=development
PORT=3000

# Database Configuration
# Using memory mode by default (no external database needed)
DATABASE_URL=memory://localhost

# Vector Database (Memory by default)
VECTOR_DB_PROVIDER=memory
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_API_KEY=
VECTOR_COLLECTION=forever_knowledge

# OpenAI Configuration (Optional - only needed if using OpenAI provider)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Agent Configuration
AGENT_MAX_DEPTH=5
AGENT_TIMEOUT=30000

# Logging
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/forever.log

# Security
JWT_SECRET=your-super-secret-jwt-key-here-for-development-use-only
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Caching
CACHE_TTL_MS=300000
REDIS_URL=
