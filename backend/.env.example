# 环境变量配置示例
# 复制此文件为 .env 并填写实际配置

# 应用配置
APP_NAME=Forever
APP_ENV=development
DEBUG=true

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./data/forever.db

# 大模型配置
LLM_PROVIDER=openai

# OpenAI 配置
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Ollama 配置（如果使用本地模型）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# 文件管理配置
FILE_STORAGE_PATH=./storage
MAX_FILE_SIZE=104857600

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
