{
  "name": "forever-ai",
  "version": "1.0.0",
  "description": "7-layer personality simulation pyramid for digital immortality. Based on Stanford Generative Agents + Sentipolis.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "backend/core",
    "examples"
  ],
  "bin": {
    "forever": "./examples/chat-ultimate.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/badhope/forever.git"
  },
  "homepage": "https://badhope.github.io/forever/publish.html",
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "chat": "tsx examples/chat-ultimate.ts",
    "publish:pages": "gh-pages -d . --src publish.html",
    "publish:npm": "npm publish --access public"
  },
  "keywords": [
    "ai",
    "agent",
    "personality",
    "generative-agents",
    "character-ai",
    "digital-immortality",
    "grief-therapy",
    "digital-legacy",
    "pad-emotion-model",
    "ocean-personality"
  ],
  "author": "badhope",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^0.1.0",
    "@langchain/community": "^0.0.1",
    "langgraph": "^0.0.38",
    "@zilliz/milvus2-sdk-node": "^2.3.0",
    "ioredis": "^5.3.0",
    "pg": "^8.11.0",
    "@xenova/transformers": "^2.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
