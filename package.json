{
  "name": "forever-ai",
  "version": "2.0.0",
  "description": "Forever is a TypeScript-native AI Agent framework featuring multi-agent orchestration (pipeline, parallel, debate, handoffs), unified LLM adapter for 16+ platforms, 5 thinking strategies (ReAct, CoT, ToT, Self-Reflection, Self-Refine), end-to-end RAG pipeline, MCP (Model Context Protocol) support, graph-based workflow engine, and comprehensive safety guardrails. Inspired by digital legacy preservation, designed for building emotionally intelligent AI companions and autonomous agent systems.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/badhope/forever.git"
  },
  "homepage": "https://github.com/badhope/forever",
  "bugs": {
    "url": "https://github.com/badhope/forever/issues"
  },
  "scripts": {
    "chat": "tsx examples/chat-complete.ts",
    "chat:simple": "tsx examples/chat-simple.ts",
    "chat:ultimate": "tsx examples/chat-ultimate.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset --force",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "dev": "tsx watch backend/main.ts",
    "demo": "tsx backend/examples/quickstart-demo.ts",
    "start": "tsx backend/main.ts"
  },
